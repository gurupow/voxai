# OAuth Providers (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_ID=""
GITHUB_SECRET=""

# AI Providers
OPENAI_API_KEY="sk-..."
ELEVENLABS_API_KEY="..."

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
